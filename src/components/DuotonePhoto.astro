---
/**
 * DuotonePhoto: rosa-mexicano + aubergine duotone on any portrait.
 *   - Highlights become rosa (background of figure).
 *   - Image desaturated + multiplied over rosa.
 *   - Aubergine layer with mix-blend-mode: lighten lifts shadows.
 */
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import emilioPortrait from '../assets/emilio-portrait.jpg';

export interface Props {
  src?: ImageMetadata;
  alt: string;
  caption?: string;
  captionPrefix?: string;
  loading?: 'lazy' | 'eager';
}

const {
  src = emilioPortrait,
  alt,
  caption,
  captionPrefix,
  loading = 'lazy',
} = Astro.props;
---

<figure class="duotone-photo-wrap">
  <div class="duotone-photo">
    <Picture
      src={src}
      alt={alt}
      formats={['avif', 'webp']}
      fallbackFormat="jpg"
      widths={[400, 600, 800, 1200]}
      sizes="(max-width: 768px) 90vw, 400px"
      loading={loading}
      decoding="async"
    />
  </div>
  {
    caption && (
      <figcaption class="duotone-photo-caption">
        {captionPrefix && <strong>{captionPrefix}.</strong>}
        {caption}
      </figcaption>
    )
  }
</figure>
