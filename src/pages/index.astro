---
/**
 * Home — entity statement, current focus, navigation hub.
 * Per BRIEF Section 4.1.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---

<BaseLayout page="home" path="/">
  <div class="coord-strip" slot="coord-strip">
    <span>Tijuana <span class="dot-pink">●</span> Mexico · Cross-border MX-US</span>
    <span>32°31′N · 117°02′W · Est. 2014</span>
  </div>

  <h1 class="hero-name">
    <span class="hero-first">Emilio</span>
    <span class="hero-last">Alcolea</span>
  </h1>

  <p class="tag-line">
    Marketing operator and Tersefy founder. Twelve years across markets that don't usually share a resume.
  </p>

  <div class="chips">
    <span class="chip chip-rosa">Healthcare</span>
    <span class="chip chip-ochre">Tech</span>
    <span class="chip chip-cobalt">Government</span>
    <span class="chip chip-green">Politics</span>
    <span class="chip chip-dark">Cross-border MX × US</span>
    <span class="chip chip-rosa">Founder</span>
    <span class="chip chip-ochre">Operator</span>
  </div>

  <div class="prose with-drop-cap">
    <p>
      I'm building <a href={site.social.tersefy}>Tersefy</a>, a doctor-first AI Visibility firm for medical tourism doctors and practices in Tijuana. Before Tersefy, twelve years across medical tourism (VIDA Wellness & Beauty), municipal government (City of Boca del Río), education non-profits (UNETE), political campaigns at the federal, state, and municipal levels, and global brand work for Dell, Amazon, Toyota, and Microsoft.
    </p>
    <p>
      The flagship result: at VIDA, Cost Per Surgery dropped from $1,300 to $490, a 62% cut. The methodology behind that cut became Tersefy.
    </p>
  </div>

  <div class="flagship">
    <div class="flagship-inner">
      <div class="flagship-label">Flagship Result · VIDA Wellness & Beauty</div>
      <div class="flagship-stat">
        $1,300<span class="arrow"> → </span>$490
        <span class="pct">−62%</span>
      </div>
      <div class="flagship-desc">
        Cost Per Surgery cut at VIDA Wellness & Beauty Center while reducing total ad spend by 20%. The methodology behind that cut became Tersefy.
      </div>
    </div>
  </div>

  <h2 class="h2-rosa">Now</h2>

  <div class="now-item">
    <div class="now-meta">/01 · Building</div>
    <div class="now-name">Tersefy</div>
    <div class="now-desc">
      Doctor-first AI Visibility / GEO / AEO / SEO for medical tourism doctors and practices.
      <a href={site.social.tersefy}>tersefy.com →</a>
    </div>
  </div>

  <div class="now-item cobalt">
    <div class="now-meta">/02 · Writing</div>
    <div class="now-name">The Insider Dispatch</div>
    <div class="now-desc">
      Weekly English-language newsletter on marketing operations, AI search, and growth strategy for operators in Mexico.
      <a href={site.social.substack}>alcolea.substack.com →</a>
    </div>
  </div>

  <h2 class="h2-ochre">More</h2>

  <ul class="more-list">
    <li>
      <a href="/about">
        <span class="num">01</span>
        <span class="name">About<span class="meta">long-form bio · career arc · how I got here</span></span>
        <span class="arrow">→</span>
      </a>
    </li>
    <li>
      <a href="/writing">
        <span class="num">02</span>
        <span class="name">Writing<span class="meta">published work, case studies, methodology</span></span>
        <span class="arrow">→</span>
      </a>
    </li>
    <li>
      <a href="/resume">
        <span class="num">03</span>
        <span class="name">Resume<span class="meta">full CV with metrics, certifications, technical skills</span></span>
        <span class="arrow">→</span>
      </a>
    </li>
    <li>
      <a href="/contact">
        <span class="num">04</span>
        <span class="name">Contact<span class="meta">how to reach me · email · linkedin · social</span></span>
        <span class="arrow">→</span>
      </a>
    </li>
  </ul>
</BaseLayout>
