---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <main class="container" style="padding-top: 80px; padding-bottom: 80px;">
    <p style="font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.18em; color: var(--ink-muted);">
      emilioalcolea.com · phase 1 foundation
    </p>
    <h1 style="font-family: var(--font-display); font-size: clamp(64px, 12vw, 130px); line-height: 0.85; letter-spacing: -0.035em; margin-top: 24px;">
      <span style="display: block; font-weight: 600;">Emilio</span>
      <span
        style="display: block; font-family: var(--font-display-italic); font-style: italic; font-weight: 800; font-variation-settings: 'SOFT' 100, 'WONK' 100; color: var(--rosa); margin-left: 0.15em;"
      >Alcolea</span>
    </h1>
    <p style="margin-top: 32px; font-family: var(--font-display); font-style: italic; font-size: 22px; line-height: 1.3; border-left: 4px solid var(--rosa); padding-left: 16px;">
      Site under construction. Phase 1 foundation in place. Real content lands in Phase 4.
    </p>
  </main>
</BaseLayout>
