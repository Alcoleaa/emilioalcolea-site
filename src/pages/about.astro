---
/**
 * About — long-form bio. Per BRIEF Section 4.2.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import DuotonePhoto from '../components/DuotonePhoto.astro';
import ThesisCallout from '../components/ThesisCallout.astro';

const faq = [
  {
    q: 'Who is Emilio Alcolea?',
    a: 'Marketing operator and founder of Tersefy. Built Tersefy in September 2025 in Tijuana, Mexico, after twelve years operating across medical tourism, education non-profits, municipal government, political campaigns, and global brand work for Dell, Amazon, Toyota, and Microsoft.',
  },
  {
    q: 'What is Tersefy?',
    a: 'A doctor-first AI Visibility firm for medical tourism doctors and practices in Tijuana. Tersefy applies a documented Generative Engine Optimization, Answer Engine Optimization, and SEO methodology to make doctors discoverable in ChatGPT, Claude, Perplexity, Gemini, and Google AI Overviews. Built on the acquisition methodology developed at VIDA Wellness & Beauty Center.',
  },
  {
    q: 'What does Emilio Alcolea consult on?',
    a: 'AI Visibility and GEO, AEO, and SEO for doctors and medical practices. Marketing operations and revenue operations for service businesses with cross-border MX-US dynamics. Available for consulting engagements through Tersefy.',
  },
  {
    q: 'Where is Emilio Alcolea based?',
    a: 'Tijuana, Baja California, Mexico. Operating across the cross-border MX-US market. Bilingual native Spanish, professional English.',
  },
  {
    q: 'What is the documented result behind Tersefy?',
    a: 'At VIDA Wellness & Beauty Center, Cost Per Surgery dropped from $1,300 to $490, a 62% reduction, while reducing total ad spend by 20%. The methodology behind that cut is what Tersefy now applies to other doctors and medical practices.',
  },
  {
    q: "What is Emilio Alcolea's experience in political campaigns?",
    a: 'Directed end-to-end campaign operations as Principal Consultant from 2017 to 2021 for candidates at federal, state, and municipal levels in Mexico, including federal deputies, senators, mayors, and state governors. Scope covered marketing strategy, messaging, opposition research, data-driven narratives, and election-day field operations. Multiple winning campaigns across cycles.',
  },
  {
    q: "What is Emilio Alcolea's experience in government communications?",
    a: "Served as Deputy Director of Communications and Public Relations at the City of Boca del Río (Mexican municipal government) from November 2017 to December 2021. Reported directly to the City Mayor. Led the launch of Visit Boca, the city's national tourism brand, driving +270% web traffic and increasing annual visitation from 2.3 million to over 2.7 million. Directed digital strategy across the full municipal account ecosystem and managed crisis communications, achieving +60% engagement growth.",
  },
  {
    q: "What is Emilio Alcolea's experience with global brand campaigns?",
    a: 'Served as Creative Director at Agency Gallo Reyna in Veracruz, Mexico from January 2014 to September 2017, leading campaigns for Dell, Amazon, Toyota, and Microsoft alongside regional clients. Managed agency P&L and a 15-person creative team, increasing agency profits by 30%. Also organized a major Esports tournament with sponsors including Logitech and HyperX.',
  },
  {
    q: "What is Emilio Alcolea's experience in non-profit fundraising?",
    a: 'Served as Senior Digital Strategy and Communication Manager at UNETE (Mexican education technology non-profit) from May 2022 to June 2023. Designed cross-border MX-US digital fundraising strategies that drove +25% growth in online donations. Consolidated strategic partnerships with global players including Dell, Bloomberg, and Nacional Monte de Piedad.',
  },
  {
    q: "What is Emilio Alcolea's experience in cross-border MX-US marketing?",
    a: 'Cross-border MX-US strategy is the through-line of the last decade. Active across non-profit fundraising at UNETE (2022 to 2023), Senior Marketing Consultant work for Washington Vascular Specialists (2021 to 2023, US-based vascular medicine practice), and Chief Sales and Marketing Officer at VIDA Wellness & Beauty Center (2023 to 2026, Tijuana medical tourism serving US patients). Bilingual native Spanish and professional English. Based in Tijuana, the largest cross-border city on the MX-US border.',
  },
  {
    q: 'What companies has Emilio Alcolea worked with?',
    a: 'Direct employer roles include VIDA Wellness & Beauty Center, Washington Vascular Specialists, UNETE, City of Boca del Río Municipal Government, and Agency Gallo Reyna. Brand campaign work covered Dell, Amazon, Toyota, Microsoft, Aeroméxico, Hilton, Logitech, HyperX. Partnership and collaboration work included Bloomberg and Nacional Monte de Piedad. Political campaigns at federal, state, and municipal levels with candidates whose names remain confidential.',
  },
  {
    q: "How is Emilio Alcolea's personal work related to Tersefy?",
    a: "Tersefy is the firm Emilio founded in September 2025 based on the patient acquisition methodology he developed as Chief Sales and Marketing Officer at VIDA Wellness & Beauty Center. Tersefy is one expression of Emilio's broader practice in marketing operations, revenue operations, and cross-border MX-US growth. The personal site emilioalcolea.com documents his full professional history across five industries. The firm site tersefy.com documents the specific service offering for surgeon-led medical practices in Tijuana.",
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://emilioalcolea.com/about/#faq',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
};
---

<BaseLayout page="about" path="/about" schema={[faqSchema]}>
  <div class="coord-strip" slot="coord-strip">
    <span>About <span class="dot-pink">●</span> Emilio Alcolea</span>
    <span>Tijuana · MX-US · Est. 2014</span>
  </div>

  <div class="page-label">
    <span>/about</span>
  </div>

  <h1 class="page-title">Marketing operator. Tersefy founder.</h1>

  <DuotonePhoto
    src="/emilio-portrait.jpg"
    alt="Emilio Alcolea, portrait, Tijuana 2026."
    captionPrefix="Right"
    caption="Portrait, May 2026. Tijuana coastline."
  />

  <p class="bio-lead">
    I am a marketing operator. I founded Tersefy in September 2025, a doctor-first AI Visibility firm for medical tourism doctors and practices in Tijuana.
  </p>

  <div class="prose">
    <p>
      The firm exists because I spent three years as Chief Sales & Marketing Officer at VIDA Wellness & Beauty Center, where I cut Cost Per Surgery from $1,300 to $490, a 62% reduction. The methodology behind that cut turned out to be replicable beyond a single clinic. Tersefy is what I am building on top of it.
    </p>
  </div>

  <ThesisCallout label="The thesis">
    <p>
      Doctors competing on paid ads forever is not a defensible strategy. Content, SEO, AI visibility, and professional reputation are.
    </p>
    <p>
      None of this is anti-ads. I currently manage paid media across multiple client accounts, including individual accounts exceeding $172k USD monthly. Ads should be a lever, not a lifeline.
    </p>
  </ThesisCallout>

  <div class="prose">
    <p>
      Before Tersefy, I spent twelve years operating across industries that do not usually share the same resume: medical tourism, education non-profits, municipal government, political campaigns, and global brand work. The outputs were different in each: surgical patients booked, donations raised, city visitation grown, elections won, brand consideration earned. The discipline underneath was constant: build the operation that produces the result, then run it under pressure.
    </p>
  </div>

  <h2 class="h2-rosa">Career</h2>

  <div class="prose">
    <p>
      I started in 2014 as Creative Director at Agency Gallo Reyna in Veracruz, leading creative direction and campaigns for Dell, Amazon, Toyota, and Microsoft alongside regional clients. Three years later, I went independent as a consultant. That is where things got interesting.
    </p>
    <p>
      I started running political campaigns at the federal, state, and municipal levels, directing end-to-end operations for candidates that included federal deputies, senators, mayors, and state governors. Multiple winning campaigns across cycles. The political work taught me something corporate marketing never could: how to move messaging fast, under pressure, with consequences that decide elections.
    </p>
    <p>
      In 2017 I joined the City of Boca del Río as Deputy Director of Communication & Public Relations, reporting to the Mayor. Led the launch of Visit Boca, the city's national tourism brand, which drove +270% web traffic growth and grew annual visitation from 2.3M to over 2.7M in the first year, with brand collaborations including Aeroméxico and Hilton. Managed the full municipal account ecosystem: the Mayor's personal channels, government communications, DIF Municipal, the Orquesta Filarmónica de Boca del Río, the Orquestando Armonía children's music program, and every operating dependency, handling 6,000+ daily messages in aggregate.
    </p>
    <p>
      After government, I went non-profit. As Senior Digital Strategy & Communication Manager at UNETE in Mexico City, I designed cross-border digital fundraising strategies that drove +25% growth in online donations, with partnerships including Dell, Bloomberg, and Nacional Monte de Piedad.
    </p>
    <p>
      Then VIDA in 2023. Medical tourism. P&L governance, zero-based budgeting, AI-driven lead routing roadmap, customer experience framework, ICP segmentation across MX and US markets. The Cost Per Surgery cut from $1,300 to $490 while reducing total ad spend by 20%. The lessons of that role became the foundation of Tersefy.
    </p>
  </div>

  <h2 class="h2-cobalt">Writing</h2>

  <div class="prose">
    <p>
      Every week I publish <a class="cobalt" href="https://alcolea.substack.com">The Insider Dispatch</a>, an English-language newsletter on marketing operations, AI search, and growth strategy for operators in Mexico. Across my career I have produced 6,000+ ghostwritten articles for clients in medical, wellness, lifestyle, marketing, and tech. At Tersefy I have shipped bilingual content on AI Visibility, GEO, AEO, and medical tourism marketing, plus a published methodology and documented case studies.
    </p>
  </div>

  <h2 class="h2-ochre">How I work</h2>

  <ul class="how-i-work">
    <li><span>Bilingual native Spanish, professional English. Based in Tijuana.</span></li>
    <li><span>I ship working systems, not decks.</span></li>
    <li><span>Direct communication, no hedging.</span></li>
    <li><span>If I tell you a number, I can prove it.</span></li>
  </ul>

  <h2 class="h2-green" id="faq">Common questions</h2>

  <dl class="faq">
    {faq.map((item) => (
      <div class="faq-item">
        <dt class="faq-q">{item.q}</dt>
        <dd class="faq-a">{item.a}</dd>
      </div>
    ))}
  </dl>
</BaseLayout>
