---
/**
 * BaseLayout
 *
 * Wraps every page with: full <head> (meta, canonical, OG, Twitter, fonts),
 * Person JSON-LD, body grid background, SiteNav, Footer, DeployBar.
 *
 * Page content goes in the default slot, which sits inside <main class="container">.
 * Pages that need a coord-strip render it in the optional `coord-strip` slot
 * (rendered above the nav, full-bleed).
 */
import { site, pageMeta, type PageKey } from '../data/site';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import DeployBar from '../components/DeployBar.astro';

import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600.css';
import '@fontsource/cormorant-garamond/700.css';
import '@fontsource/cormorant-garamond/400-italic.css';
import '@fontsource/cormorant-garamond/500-italic.css';
import '@fontsource/cormorant-garamond/600-italic.css';
import '@fontsource/cormorant-garamond/700-italic.css';
import '@fontsource-variable/fraunces/wght.css';
import '@fontsource-variable/fraunces/wght-italic.css';
import '@fontsource/karla/300.css';
import '@fontsource/karla/400.css';
import '@fontsource/karla/500.css';
import '@fontsource/karla/600.css';
import '@fontsource/karla/700.css';
import '@fontsource/karla/800.css';
import '@fontsource/bebas-neue/400.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/700.css';

import '../styles/global.css';

export interface Props {
  /** Page key into pageMeta. When set, title/description/ogType/ogImage default from pageMeta[page]. */
  page?: PageKey;
  title?: string;
  description?: string;
  /** Path-only canonical, e.g. "/about". Joined with site.url. */
  path?: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'profile';
  /** Optional extra JSON-LD blocks (e.g. ProfilePage on /resume). */
  schema?: Record<string, unknown>[];
  lang?: string;
}

const {
  page,
  title,
  description,
  path = Astro.url.pathname,
  ogImage,
  ogType,
  schema = [],
  lang = site.locale,
} = Astro.props;

const meta = page ? pageMeta[page] : null;
const resolvedTitle = title
  ? `${title}${site.titleSuffix}`
  : meta
    ? meta.title
    : site.defaultTitle;
const resolvedDescription = description ?? meta?.description ?? site.defaultDescription;
const resolvedOgImage = ogImage ?? meta?.ogImage ?? site.ogImage;
const resolvedOgType: 'website' | 'article' | 'profile' = ogType ?? meta?.ogType ?? 'website';
const canonical = new URL(path === '/' ? '/' : path.replace(/\/$/, ''), site.url).toString();
const ogImageAbs = new URL(resolvedOgImage, site.url).toString();

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': 'https://emilioalcolea.com/#person',
  name: site.author.name,
  url: site.url,
  image: new URL(site.portrait, site.url).toString(),
  sameAs: [
    site.social.linkedin,
    site.social.substack,
    site.social.tersefy,
    site.social.github,
  ],
  jobTitle: 'Founder',
  worksFor: {
    '@type': 'Organization',
    '@id': 'https://tersefy.com/#organization',
    name: 'Tersefy',
    url: site.social.tersefy,
  },
  hasOccupation: {
    '@type': 'Occupation',
    name: 'Marketing Operator and Founder',
    occupationLocation: {
      '@type': 'City',
      name: 'Tijuana',
      containedInPlace: {
        '@type': 'AdministrativeArea',
        name: 'Baja California',
        containedInPlace: {
          '@type': 'Country',
          name: 'Mexico',
        },
      },
    },
    skills:
      'AI Visibility, Generative Engine Optimization, Answer Engine Optimization, SEO, Marketing Operations, Revenue Operations, Cross-border Marketing',
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: site.author.city,
    addressRegion: site.author.region,
    addressCountry: site.author.country,
  },
  alumniOf: {
    '@type': 'EducationalOrganization',
    name: 'Tec Milenio',
  },
  hasCredential: site.hasCredential.map((c) => ({
    '@type': 'EducationalOccupationalCredential',
    name: c.name,
    credentialCategory: 'certification',
    recognizedBy: {
      '@type': 'Organization',
      ...c.recognizedBy,
    },
  })),
  knowsAbout: site.knowsAbout,
  knowsLanguage: site.knowsLanguage,
  description: site.personDescription,
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{resolvedTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <meta property="og:site_name" content={site.name} />
    <meta property="og:type" content={resolvedOgType} />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:locale" content={lang === 'es' ? 'es_MX' : 'en_US'} />
    {resolvedOgType === 'profile' && (
      <>
        <meta property="profile:first_name" content="Emilio" />
        <meta property="profile:last_name" content="Alcolea" />
      </>
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImageAbs} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(personSchema)}
    />
    {
      schema.map((block) => (
        <script type="application/ld+json" set:html={JSON.stringify(block)} />
      ))
    }

    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      window.gtag = window.gtag || function () { window.dataLayer.push(arguments); };
      window.gtag('js', new Date());
      window.gtag('config', 'G-9HC1ST057L');
      window.addEventListener('load', function () {
        var s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-9HC1ST057L';
        s.async = true;
        document.head.appendChild(s);
      });
    </script>
  </head>
  <body>
    <div class="page-shell">
      <slot name="coord-strip" />
      <div class="page-content container">
        <SiteNav />
        <main>
          <slot />
        </main>
        <Footer />
      </div>
      <DeployBar />
    </div>
  </body>
</html>
