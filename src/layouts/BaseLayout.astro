---
/**
 * BaseLayout
 *
 * Wraps every page with: full <head> (meta, canonical, OG, Twitter, fonts),
 * Person JSON-LD, body grid background, SiteNav, Footer, DeployBar.
 *
 * Page content goes in the default slot, which sits inside <main class="container">.
 * Pages that need a coord-strip render it in the optional `coord-strip` slot
 * (rendered above the nav, full-bleed).
 */
import { site } from '../data/site';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import DeployBar from '../components/DeployBar.astro';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  /** Path-only canonical, e.g. "/about". Joined with site.url. */
  path?: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'profile';
  /** Optional extra JSON-LD blocks (e.g. ProfilePage on /resume). */
  schema?: Record<string, unknown>[];
  lang?: string;
}

const {
  title,
  description = site.defaultDescription,
  path = Astro.url.pathname,
  ogImage = site.ogImage,
  ogType = 'website',
  schema = [],
  lang = site.locale,
} = Astro.props;

const fullTitle = title ? `${title}${site.titleSuffix}` : site.defaultTitle;
const canonical = new URL(path === '/' ? '/' : path.replace(/\/$/, ''), site.url).toString();
const ogImageAbs = new URL(ogImage, site.url).toString();

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': 'https://emilioalcolea.com/#person',
  name: site.author.name,
  url: site.url,
  image: new URL(site.portrait, site.url).toString(),
  sameAs: [
    site.social.linkedin,
    site.social.substack,
    site.social.tersefy,
    site.social.github,
  ],
  jobTitle: 'Founder',
  worksFor: {
    '@type': 'Organization',
    '@id': 'https://tersefy.com/#organization',
    name: 'Tersefy',
    url: site.social.tersefy,
  },
  hasOccupation: {
    '@type': 'Occupation',
    name: 'Marketing Operator and Founder',
    occupationLocation: {
      '@type': 'City',
      name: 'Tijuana',
      containedInPlace: {
        '@type': 'AdministrativeArea',
        name: 'Baja California',
        containedInPlace: {
          '@type': 'Country',
          name: 'Mexico',
        },
      },
    },
    skills:
      'AI Visibility, Generative Engine Optimization, Answer Engine Optimization, SEO, Marketing Operations, Revenue Operations, Cross-border Marketing',
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: site.author.city,
    addressRegion: site.author.region,
    addressCountry: site.author.country,
  },
  alumniOf: {
    '@type': 'EducationalOrganization',
    name: 'Tec Milenio',
  },
  hasCredential: site.hasCredential.map((c) => ({
    '@type': 'EducationalOccupationalCredential',
    name: c.name,
    credentialCategory: 'certification',
    recognizedBy: {
      '@type': 'Organization',
      ...c.recognizedBy,
    },
  })),
  knowsAbout: site.knowsAbout,
  knowsLanguage: site.knowsLanguage,
  description: site.personDescription,
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <meta property="og:site_name" content={site.name} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:locale" content={lang === 'es' ? 'es_MX' : 'en_US'} />
    {ogType === 'profile' && (
      <>
        <meta property="profile:first_name" content="Emilio" />
        <meta property="profile:last_name" content="Alcolea" />
      </>
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,100..900,0..100,0..1;1,9..144,100..900,0..100,0..1&family=Karla:wght@300;400;500;600;700;800&family=Bebas+Neue&family=JetBrains+Mono:wght@400;500;700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,100..900,0..100,0..1;1,9..144,100..900,0..100,0..1&family=Karla:wght@300;400;500;600;700;800&family=Bebas+Neue&family=JetBrains+Mono:wght@400;500;700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,100..900,0..100,0..1;1,9..144,100..900,0..100,0..1&family=Karla:wght@300;400;500;600;700;800&family=Bebas+Neue&family=JetBrains+Mono:wght@400;500;700&display=swap"
      />
    </noscript>

    <script
      type="application/ld+json"
      set:html={JSON.stringify(personSchema)}
    />
    {
      schema.map((block) => (
        <script type="application/ld+json" set:html={JSON.stringify(block)} />
      ))
    }

    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      window.gtag = window.gtag || function () { window.dataLayer.push(arguments); };
      window.gtag('js', new Date());
      window.gtag('config', 'G-9HC1ST057L');
      window.addEventListener('load', function () {
        var s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-9HC1ST057L';
        s.async = true;
        document.head.appendChild(s);
      });
    </script>
  </head>
  <body>
    <div class="page-shell">
      <slot name="coord-strip" />
      <div class="page-content container">
        <SiteNav />
        <main>
          <slot />
        </main>
        <Footer />
      </div>
      <DeployBar />
    </div>
  </body>
</html>
